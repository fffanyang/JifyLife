{
  "name": "jifylife",
  "version": "0.1.0",
  "private": true,
  "description": "P人也能变J人 — 个人效率管理工具",
  "scripts": {
    "dev": "pnpm --filter @jifylife/web dev",
    "dev:web": "pnpm --filter @jifylife/web dev",
    "dev:server": "pnpm --filter @jifylife/server dev",
    "build": "pnpm build:web",
    "build:web": "pnpm --filter @jifylife/web build",
    "build:server": "pnpm --filter @jifylife/server build",
    "preview": "pnpm --filter @jifylife/web preview",
    "build:prod": "pnpm build:web && pnpm build:server && rm -rf apps/server/public && cp -r apps/web/dist apps/server/public",
    "start": "NODE_ENV=production node apps/server/dist/index.js",
    "db:push": "pnpm --filter @jifylife/server db:push",
    "db:migrate": "pnpm --filter @jifylife/server db:migrate",
    "lint": "pnpm -r lint",
    "clean": "pnpm -r clean && rm -rf apps/server/public"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "esbuild",
      "prisma"
    ]
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
